{
    "name": "prestashop/getresponse",
    "homepage": "https://github.com/GetResponse/GetresponseForPrestashop",
    "description": "GetResponse for PrestaShop",
    "authors": [
        {
            "name": "PrestaShop SA",
            "email": "contact@prestashop.com"
        }
    ],
    "config": {
        "preferred-install": "dist",
        "prepend-autoloader": false,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "type": "prestashop-module",
    "minimum-stability": "stable",
    "require": {
        "php": ">= 7.2",
        "ext-json": "*",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^5.0 || ^6.0 || ^7.0 || ^8.0 || ^9.0",
        "prestashop/php-dev-tools": "^5.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "captainhook/captainhook": "^5.14",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpstan/phpstan": "^1.12 || ^2.1",
        "prestashop/autoindex": "^2.1",
        "prestashop/header-stamp": "^2.6",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "GetResponse\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GetResponse\\Tests\\": "tests/"
        }
    },
    "author": "PrestaShop",
    "license": "AFL-3.0",
    "scripts": {
        "autoindex-fix": "vendor/bin/autoindex prestashop:add:index . --exclude=tests,vendor",
        "licenses-fix": "vendor/bin/header-stamp --license=assets/afl.txt --exclude=vendor --display-report",
        "licenses-check": "vendor/bin/header-stamp --license=assets/afl.txt --exclude=vendor --display-report --dry-run",
        "php-cs-fix": "php vendor/bin/php-cs-fixer fix --using-cache=no",
        "php-cs-check": "php vendor/bin/php-cs-fixer fix --dry-run --diff --using-cache=no",
        "phpstan-check": "_PS_ROOT_DIR_=../../ vendor/bin/phpstan analyse --configuration=tests/phpstan/phpstan.neon --memory-limit=256M",
        "tests": "vendor/bin/phpunit --configuration tests/phpunit.xml",
        "fix": [
            "@autoindex-fix",
            "@licenses-fix",
            "@php-cs-fix"
        ],
        "check": [
            "@licenses-check",
            "@php-cs-check",
            "@phpstan-check"
        ],
        "check-all": [
            "@check",
            "@tests"
        ]
    }
}
